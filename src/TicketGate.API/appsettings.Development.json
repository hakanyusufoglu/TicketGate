{
  "Serilog": {
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.EntityFrameworkCore.Database.Command": "Warning",
        "Microsoft.AspNetCore": "Warning",
        "System": "Warning"
      }
    }
  },
  "ConnectionStrings": {
    "Booking": "Host=localhost;Port=55432;Database=ticketgate;Username=ticketgate;Password=ticketgate;Search Path=booking;Maximum Pool Size=20;Minimum Pool Size=5;",
    "Payment": "Host=localhost;Port=55432;Database=ticketgate;Username=ticketgate;Password=ticketgate;Search Path=payment;Maximum Pool Size=10;Minimum Pool Size=2;",
    "Event": "Host=localhost;Port=55432;Database=ticketgate;Username=ticketgate;Password=ticketgate;Search Path=events",
    "Identity": "Host=localhost;Port=55432;Database=ticketgate;Username=ticketgate;Password=ticketgate;Search Path=identity",
    "Redis": "localhost:6379"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092"
  },
  "Elasticsearch": {
    "Uri": "http://localhost:9200"
  },
  "Cors": {
    "AllowedOrigins": [
      "https://ticketgate.io",
      "https://www.ticketgate.io"
    ]
  },
  "RateLimiting": {
    "Enabled": true,
    "Auth": {
      "PermitLimit": 10,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Reserve": {
      "PermitLimit": 5,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Queue": {
      "PermitLimit": 1,
      "WindowSeconds": 5,
      "QueueLimit": 0
    },
    "Read": {
      "PermitLimit": 60,
      "WindowSeconds": 60,
      "QueueLimit": 0
    },
    "Sse": {
      "PermitLimit": 5,
      "WindowSeconds": 60,
      "QueueLimit": 0
    }
  },
  "ResponseCompression": {
    "EnableForHttps": true
  },
  "EventCacheSettings": {
    "EventDetailTtlMinutes": 10,
    "SeatMapTtlMinutes": 30,
    "EventListOutputCacheTtlSeconds": 60
  },
  "Jwt": {
    "Issuer": "TicketGate",
    "Audience": "TicketGate.Clients",
    "SecretKey": "TicketGateDevelopmentSecretKeyWithAtLeastThirtyTwoCharacters",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7
  },
  "BookingSettings": {
    "LockTtlSeconds": 600,
    "MaxCheckoutCapacity": 10,
    "QueueDispatcherIntervalSeconds": 5,
    "QueueDispatchBatchSize": 10,
    "QueuePositionPublishBatchSize": 100,
    "QueuePositionPublishDelayMilliseconds": 10
  },
  "OutboxSettings": {
    "PollingIntervalSeconds": 5,
    "BatchSize": 10,
    "MaxRetryCount": 3
  },
  "SseSettings": {
    "HeartbeatIntervalSeconds": 15
  }
}
