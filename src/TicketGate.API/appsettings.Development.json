{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Booking": "Host=localhost;Port=55432;Database=ticketgate;Username=ticketgate;Password=ticketgate;Search Path=booking",
    "Payment": "Host=localhost;Port=55432;Database=ticketgate;Username=ticketgate;Password=ticketgate;Search Path=payment",
    "Event": "Host=localhost;Port=55432;Database=ticketgate;Username=ticketgate;Password=ticketgate;Search Path=events",
    "Identity": "Host=localhost;Port=55432;Database=ticketgate;Username=ticketgate;Password=ticketgate;Search Path=identity",
    "Redis": "localhost:6379"
  },
  "Kafka": {
    "BootstrapServers": "localhost:9092"
  },
  "Elasticsearch": {
    "Uri": "http://localhost:9200"
  },
  "Jwt": {
    "Issuer": "TicketGate",
    "Audience": "TicketGate.Clients",
    "SecretKey": "TicketGateDevelopmentSecretKeyWithAtLeastThirtyTwoCharacters",
    "AccessTokenExpirationMinutes": 15,
    "RefreshTokenExpirationDays": 7,
    "ClockSkewMinutes": 2
  },
  "BookingSettings": {
    "LockTtlSeconds": 600,
    "MaxCheckoutCapacity": 10,
    "QueueDispatcherIntervalSeconds": 5,
    "QueueDispatchBatchSize": 10
  },
  "OutboxSettings": {
    "PollingIntervalSeconds": 5,
    "BatchSize": 10,
    "MaxRetryCount": 3
  },
  "SseSettings": {
    "HeartbeatIntervalSeconds": 15
  }
}
