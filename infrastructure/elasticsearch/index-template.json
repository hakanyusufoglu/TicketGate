{
  "index_patterns": [
    "ticketgate-*"
  ],
  "template": {
    "settings": {
      "number_of_shards": 1,
      "number_of_replicas": 0
    },
    "mappings": {
      "properties": {
        "@timestamp": {
          "type": "date"
        },
        "operation": {
          "type": "keyword"
        },
        "table": {
          "type": "keyword"
        },
        "ticketId": {
          "type": "keyword"
        },
        "eventId": {
          "type": "keyword"
        },
        "userId": {
          "type": "keyword"
        },
        "status": {
          "type": "keyword"
        },
        "seat": {
          "type": "keyword"
        },
        "price": {
          "type": "float"
        },
        "amount": {
          "type": "float"
        },
        "payload": {
          "type": "object"
        }
      }
    }
  }
}
