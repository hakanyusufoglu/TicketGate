{
  "name": "ticketgate-postgres-connector",
  "config": {
    "connector.class": "io.debezium.connector.postgresql.PostgresConnector",
    "database.hostname": "postgres",
    "database.port": "5432",
    "database.user": "ticketgate",
    "database.password": "ticketgate",
    "database.dbname": "ticketgate",
    "topic.prefix": "ticketgate",
    "schema.include.list": "booking,payment",
    "table.include.list": "booking.tickets,payment.payments",
    "plugin.name": "pgoutput",
    "publication.name": "ticketgate_pub",
    "slot.name": "ticketgate_slot",
    "key.converter": "org.apache.kafka.connect.json.JsonConverter",
    "key.converter.schemas.enable": "false",
    "value.converter": "org.apache.kafka.connect.json.JsonConverter",
    "value.converter.schemas.enable": "false"
  }
}
