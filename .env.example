# PostgreSQL
POSTGRES_DB=ticketgate
POSTGRES_USER=ticketgate
POSTGRES_PASSWORD=CHANGE_ME

# Redis
REDIS_PASSWORD=CHANGE_ME

# JWT
JWT_SECRET_KEY=CHANGE_ME_MIN_32_CHARS
JWT_ISSUER=ticketgate
JWT_AUDIENCE=TicketGate.Clients

# Elasticsearch
ELASTIC_PASSWORD=CHANGE_ME

# Grafana
GF_SECURITY_ADMIN_PASSWORD=CHANGE_ME

# BookingSettings
BOOKING_LOCK_TTL_SECONDS=600
BOOKING_MAX_CHECKOUT_CAPACITY=10
